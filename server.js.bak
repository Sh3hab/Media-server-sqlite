        const db = JSON.parse(fs.readFileSync('data/db.json', 'utf8'));
        const index = db.tags.findIndex(t => t.id === req.params.id);
        if (index === -1) return res.status(404).json({ error: 'غير موجود' });
        
        const deleted = db.tags.splice(index, 1)[0];
        fs.writeFileSync('data/db.json', JSON.stringify(db, null, 2));
        res.json({ success: true, message: 'تم الحذف', tag: deleted });
    } catch (error) {
        res.status(500).json({ error: 'خطأ' });
    }
});

app.post('/api/content/:contentId/tags', authenticateAdmin, (req, res) => {
    try {
        const db = JSON.parse(fs.readFileSync('data/db.json', 'utf8'));
        const { tagIds } = req.body;
        
        const contentIndex = db.series.findIndex(s => s.id === req.params.contentId);
        if (contentIndex === -1) return res.status(404).json({ error: 'المحتوى غير موجود' });
        
        const validTags = db.tags.filter(tag => tagIds.includes(tag.id));
        db.series[contentIndex].tags = validTags.map(tag => tag.name);
        
        validTags.forEach(tag => {
            const tagIndex = db.tags.findIndex(t => t.id === tag.id);
            if (tagIndex !== -1) db.tags[tagIndex].count = (db.tags[tagIndex].count || 0) + 1;
        });
        
        fs.writeFileSync('data/db.json', JSON.stringify(db, null, 2));
        res.json({ success: true, message: 'تم ربط الوسوم', tags: validTags });
    } catch (error) {
        res.status(500).json({ error: 'خطأ' });
    }
});

