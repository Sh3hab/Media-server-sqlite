    }
});

app.get('/api/search', (req, res) => {
    try {
        const query = req.query.q?.toLowerCase() || '';
        const type = req.query.type || 'all';
        const db = JSON.parse(fs.readFileSync('data/db.json', 'utf8'));
        let results = [];
        
        if (type === 'all' || type === 'series') {
            const series = db.series.filter(s => s.title.toLowerCase().includes(query) || s.description.toLowerCase().includes(query));
            results = [...results, ...series.map(s => ({ ...s, type: s.isMovie ? 'movie' : 'series' }))];
        }
        if (type === 'all' || type === 'actors') {
            const actors = db.actors.filter(a => a.name.toLowerCase().includes(query));
            results = [...results, ...actors.map(a => ({ ...a, type: 'actor' }))];
        }
        if (type === 'all' || type === 'episodes') {
            const episodes = db.episodes.filter(ep => ep.title.toLowerCase().includes(query));
            results = [...results, ...episodes.map(ep => ({ ...ep, type: 'episode' }))];
        }
        
        res.json(results);
    } catch (error) {
        res.status(500).json({ error: 'خطأ' });
    }
});

