// ==================== 3. إدارة الحلقات ====================

app.get('/api/episodes', (req, res) => {
    try {
        const db = JSON.parse(fs.readFileSync('data/db.json', 'utf8'));
        let episodes = db.episodes;
        
        if (req.query.seriesId) episodes = episodes.filter(ep => ep.seriesId === req.query.seriesId);
        if (req.query.seasonId) episodes = episodes.filter(ep => ep.seasonId === req.query.seasonId);
        
        episodes.sort((a, b) => a.episodeNumber - b.episodeNumber);
        
        const enhancedEpisodes = episodes.map(ep => {
            const series = db.series.find(s => s.id === ep.seriesId);
            const season = db.seasons.find(s => s.id === ep.seasonId);
            return {
                ...ep,
                seriesTitle: series ? series.title : 'غير معروف',
                seasonTitle: season ? season.title : 'غير معروف',
                poster: ep.poster || (series ? series.poster : '')
            };
        });
        res.json(enhancedEpisodes);
    } catch (error) {
        res.status(500).json({ error: 'خطأ' });
    }
});

app.get('/api/episodes/:id', (req, res) => {
    try {
        const db = JSON.parse(fs.readFileSync('data/db.json', 'utf8'));
        const episode = db.episodes.find(e => e.id === req.params.id);
        if (!episode) return res.status(404).json({ error: 'غير موجود' });
        
        const series = db.series.find(s => s.id === episode.seriesId);
        const season = db.seasons.find(s => s.id === episode.seasonId);
        
        res.json({
            ...episode,
            seriesTitle: series ? series.title : 'غير معروف',
            seasonTitle: season ? season.title : 'غير معروف'
        });
    } catch (error) {
        res.status(500).json({ error: 'خطأ' });
    }
});

app.post('/api/episodes', authenticateAdmin, (req, res) => {
    try {
        const db = JSON.parse(fs.readFileSync('data/db.json', 'utf8'));
        const { seriesId, seasonId, episodeNumber, title, description, videoUrl, duration, thumbnail, isFree } = req.body;
        
        const series = db.series.find(s => s.id === seriesId);
        if (!series) return res.status(404).json({ error: 'المسلسل غير موجود' });
        
        const id = 'episode_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9);
        const newEpisode = {
            id, seriesId, seasonId: seasonId || null,
            episodeNumber: parseInt(episodeNumber) || 1,
            title: title || `الحلقة ${episodeNumber}`,
            description: description || '',
            videoUrl, duration: duration || '00:00',
            thumbnail: thumbnail || series.poster,
            isFree: isFree === true || isFree === 'true',
            views: 0, likes: 0,
            createdAt: new Date().toISOString(), updatedAt: new Date().toISOString()
        };
        
        db.episodes.push(newEpisode);
        
        if (seasonId) {
            const seasonIndex = db.seasons.findIndex(s => s.id === seasonId);
            if (seasonIndex !== -1) {
                const seasonEpisodes = db.episodes.filter(ep => ep.seasonId === seasonId);
                db.seasons[seasonIndex].episodeCount = seasonEpisodes.length;
            }
        }
        
        fs.writeFileSync('data/db.json', JSON.stringify(db, null, 2));
        res.json({ success: true, message: 'تم الإضافة', episode: newEpisode });
    } catch (error) {
        res.status(500).json({ error: 'خطأ' });
    }
});

app.put('/api/episodes/:id', authenticateAdmin, (req, res) => {
    try {
        const db = JSON.parse(fs.readFileSync('data/db.json', 'utf8'));
        const index = db.episodes.findIndex(e => e.id === req.params.id);
        if (index === -1) return res.status(404).json({ error: 'غير موجود' });
        
        db.episodes[index] = { ...db.episodes[index], ...req.body, updatedAt: new Date().toISOString() };
        fs.writeFileSync('data/db.json', JSON.stringify(db, null, 2));
        res.json({ success: true, message: 'تم التحديث', episode: db.episodes[index] });
    } catch (error) {
        res.status(500).json({ error: 'خطأ' });
    }
});

