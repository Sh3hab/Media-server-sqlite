app.get('/api/actors', (req, res) => {
    try {
        const db = JSON.parse(fs.readFileSync('data/db.json', 'utf8'));
        res.json(db.actors);
    } catch (error) {
        res.status(500).json({ error: 'خطأ' });
    }
});

app.get('/api/actors/search', (req, res) => {
    try {
        const query = req.query.q?.toLowerCase() || '';
        const db = JSON.parse(fs.readFileSync('data/db.json', 'utf8'));
        const results = db.actors.filter(actor => 
            actor.name.toLowerCase().includes(query) ||
            actor.nationality?.toLowerCase().includes(query)
        );
        res.json(results);
    } catch (error) {
        res.status(500).json({ error: 'خطأ' });
    }
});

app.get('/api/actors/:id', (req, res) => {
    try {
        const db = JSON.parse(fs.readFileSync('data/db.json', 'utf8'));
        const actor = db.actors.find(a => a.id === req.params.id);
        if (!actor) return res.status(404).json({ error: 'غير موجود' });
        
        // جلب الأعمال المرتبطة (طريقة قديمة وجديدة)
        const movies = db.series.filter(s => s.isMovie && s.actors && s.actors.includes(req.params.id));
        const series = db.series.filter(s => !s.isMovie && s.actors && s.actors.includes(req.params.id));
        
        // جلب الأدوار التفصيلية
        const actorRoles = [];
        db.series.forEach(content => {
            if (content.actorRoles) {
                content.actorRoles.forEach(role => {
                    if (role.actorId === req.params.id) {
                        actorRoles.push({
                            contentId: content.id,
                            contentTitle: content.title,
                            contentType: content.isMovie ? 'movie' : 'series',
                            characterName: role.characterName,
                            role: role.role,
                            order: role.order
                        });
                    }
                });
            }
        });
        
        res.json({
            ...actor,
            movies: movies.map(m => ({ id: m.id, title: m.title, year: m.year, poster: m.poster })),
            series: series.map(s => ({ id: s.id, title: s.title, year: s.year, poster: s.poster })),
            roles: actorRoles
        });
    } catch (error) {
