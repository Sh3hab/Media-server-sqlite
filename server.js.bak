        const stats = {
            totalSeries: db.series.filter(s => !s.isMovie).length,
            totalMovies: db.series.filter(s => s.isMovie).length,
            totalSeasons: db.seasons.length,
            totalEpisodes: db.episodes.length,
            totalActors: db.actors.length,
            totalGenres: db.genres ? db.genres.length : 0,
            totalCountries: db.countries ? db.countries.length : 0,
            totalPromoted: db.series.filter(s => s.promoted).length,
            totalViews: db.series.reduce((sum, s) => sum + (s.views || 0), 0) + 
                        db.episodes.reduce((sum, ep) => sum + (ep.views || 0), 0),
            lastUpdated: new Date().toISOString()
        };
        res.json(stats);
    } catch (error) {
