});

app.delete('/api/seasons/:id', authenticateAdmin, (req, res) => {
    try {
        const db = JSON.parse(fs.readFileSync('data/db.json', 'utf8'));
        const index = db.seasons.findIndex(s => s.id === req.params.id);
        if (index === -1) return res.status(404).json({ error: 'غير موجود' });
        
        // حذف الحلقات المرتبطة
        db.episodes = db.episodes.filter(ep => ep.seasonId !== req.params.id);
        
        const deleted = db.seasons.splice(index, 1)[0];
        fs.writeFileSync('data/db.json', JSON.stringify(db, null, 2));
        res.json({ success: true, message: 'تم الحذف', season: deleted });
    } catch (error) {
        res.status(500).json({ error: 'خطأ' });
    }
});

