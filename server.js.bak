app.delete('/api/actors/:id', authenticateAdmin, (req, res) => {
    try {
        const db = JSON.parse(fs.readFileSync('data/db.json', 'utf8'));
        const index = db.actors.findIndex(a => a.id === req.params.id);
        if (index === -1) return res.status(404).json({ error: 'غير موجود' });
        
        // تنظيف العلاقات
        db.series.forEach(content => {
            if (content.actors) content.actors = content.actors.filter(id => id !== req.params.id);
            if (content.actorRoles) content.actorRoles = content.actorRoles.filter(role => role.actorId !== req.params.id);
        });
        
        const deleted = db.actors.splice(index, 1)[0];
        fs.writeFileSync('data/db.json', JSON.stringify(db, null, 2));
        res.json({ success: true, message: 'تم الحذف', actor: deleted });
    } catch (error) {
        res.status(500).json({ error: 'خطأ' });
    }
});

// ربط الممثلين بالمحتوى
app.post('/api/content/:contentId/actors', authenticateAdmin, (req, res) => {
    try {
        const db = JSON.parse(fs.readFileSync('data/db.json', 'utf8'));
        const { actorId, role, characterName, order } = req.body;
        
        const contentIndex = db.series.findIndex(s => s.id === req.params.contentId);
        if (contentIndex === -1) return res.status(404).json({ error: 'المحتوى غير موجود' });
        
        const actor = db.actors.find(a => a.id === actorId);
        if (!actor) return res.status(404).json({ error: 'الممثل غير موجود' });
        
        const actorRole = {
            actorId, actorName: actor.name,
            characterName: characterName || actor.name,
            role: role || 'ممثل',
            order: parseInt(order) || 0
        };
        
        if (!db.series[contentIndex].actorRoles) db.series[contentIndex].actorRoles = [];
        
        // تحديث أو إضافة
        const existingIndex = db.series[contentIndex].actorRoles.findIndex(ar => ar.actorId === actorId);
        if (existingIndex !== -1) {
            db.series[contentIndex].actorRoles[existingIndex] = actorRole;
        } else {
            db.series[contentIndex].actorRoles.push(actorRole);
        }
        
        // إضافة لقائمة الممثل البسيطة أيضًا للتوافق
        if (!db.series[contentIndex].actors) db.series[contentIndex].actors = [];
        if (!db.series[contentIndex].actors.includes(actorId)) db.series[contentIndex].actors.push(actorId);

        fs.writeFileSync('data/db.json', JSON.stringify(db, null, 2));
        res.json({ success: true, message: 'تم الربط', actorRole });
    } catch (error) {
        res.status(500).json({ error: 'خطأ' });
    }
});

app.delete('/api/content/:contentId/actors/:actorId', authenticateAdmin, (req, res) => {
    try {
        const db = JSON.parse(fs.readFileSync('data/db.json', 'utf8'));
        const contentIndex = db.series.findIndex(s => s.id === req.params.contentId);
        
        if (contentIndex === -1) return res.status(404).json({ error: 'المحتوى غير موجود' });
        
        if (db.series[contentIndex].actors) {
            db.series[contentIndex].actors = db.series[contentIndex].actors.filter(id => id !== req.params.actorId);
        }
        if (db.series[contentIndex].actorRoles) {
            db.series[contentIndex].actorRoles = db.series[contentIndex].actorRoles.filter(r => r.actorId !== req.params.actorId);
        }
        
        fs.writeFileSync('data/db.json', JSON.stringify(db, null, 2));
        res.json({ success: true, message: 'تم فك الربط' });
    } catch (error) {
        res.status(500).json({ error: 'خطأ' });
    }
});

app.put('/api/content/:contentId/actors/:actorId/order', authenticateAdmin, (req, res) => {
    try {
        const db = JSON.parse(fs.readFileSync('data/db.json', 'utf8'));
        const contentIndex = db.series.findIndex(s => s.id === req.params.contentId);
        if (contentIndex === -1) return res.status(404).json({ error: 'المحتوى غير موجود' });
        
        const roleIndex = db.series[contentIndex].actorRoles.findIndex(r => r.actorId === req.params.actorId);
        if (roleIndex === -1) return res.status(404).json({ error: 'الدور غير موجود' });
        
        db.series[contentIndex].actorRoles[roleIndex].order = parseInt(req.body.order) || 0;
        fs.writeFileSync('data/db.json', JSON.stringify(db, null, 2));
        res.json({ success: true, message: 'تم تحديث الترتيب' });
    } catch (error) {
        res.status(500).json({ error: 'خطأ' });
    }
});

app.get('/api/content/:contentId/actors', (req, res) => {
    try {
        const db = JSON.parse(fs.readFileSync('data/db.json', 'utf8'));
        const content = db.series.find(s => s.id === req.params.contentId);
        if (!content) return res.status(404).json({ error: 'غير موجود' });
        
        const actorRoles = content.actorRoles || [];
        actorRoles.sort((a, b) => a.order - b.order);
        
        const enhancedRoles = actorRoles.map(role => {
            const actor = db.actors.find(a => a.id === role.actorId);
            return {
                ...role,
                actorImage: actor ? actor.image : '',
                actorBio: actor ? actor.bio : '',
                actorNationality: actor ? actor.nationality : ''
            };
        });
        res.json(enhancedRoles);
    } catch (error) {
        res.status(500).json({ error: 'خطأ' });
    }
});

// ==================== 5. إدارة الأجزاء (Parts) ====================

app.get('/api/parts', (req, res) => {
    try {
        const db = JSON.parse(fs.readFileSync('data/db.json', 'utf8'));
        const parts = db.parts || [];
        const enhancedParts = parts.map(part => {
            const parent = db.series.find(s => s.id === part.parentId);
            return {
                ...part,
                parentTitle: parent ? parent.title : 'غير معروف',
                parentType: parent ? (parent.isMovie ? 'movie' : 'series') : 'unknown',
                parentPoster: parent ? parent.poster : ''
            };
        });
        res.json(enhancedParts);
    } catch (error) {
        res.status(500).json({ error: 'خطأ' });
    }
});

// مسار لجلب أجزاء محتوى معين (تم تغيير المسار لتجنب التعارض)
app.get('/api/content/:parentId/parts', (req, res) => {
    try {
        const db = JSON.parse(fs.readFileSync('data/db.json', 'utf8'));
        const parts = (db.parts || []).filter(p => p.parentId === req.params.parentId);
        parts.sort((a, b) => a.partNumber - b.partNumber);
        res.json(parts);
    } catch (error) {
        res.status(500).json({ error: 'خطأ' });
    }
});

// مسار لجلب تفاصيل جزء واحد
app.get('/api/parts/:id', (req, res) => {
    try {
        const db = JSON.parse(fs.readFileSync('data/db.json', 'utf8'));
        const part = (db.parts || []).find(p => p.id === req.params.id);
        if (!part) return res.status(404).json({ error: 'غير موجود' });
        
        const parent = db.series.find(s => s.id === part.parentId);
        res.json({
            ...part,
            parentTitle: parent ? parent.title : 'غير معروف',
            parentPoster: parent ? parent.poster : '',
            parentType: parent ? (parent.isMovie ? 'movie' : 'series') : 'unknown'
        });
    } catch (error) {
        res.status(500).json({ error: 'خطأ' });
    }
});

app.post('/api/parts', authenticateAdmin, (req, res) => {
    try {
        const db = JSON.parse(fs.readFileSync('data/db.json', 'utf8'));
        const { parentId, partNumber, title, year, poster, description, duration, videoUrl } = req.body;
        
        const parent = db.series.find(s => s.id === parentId);
        if (!parent) return res.status(404).json({ error: 'المحتوى الأصلي غير موجود' });
        
        const id = 'part_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9);
        const newPart = {
            id, parentId, parentTitle: parent.title,
            parentType: parent.isMovie ? 'movie' : 'series',
            partNumber: parseInt(partNumber) || 1,
            title: title || `الجزء ${partNumber}`,
            year: parseInt(year) || parent.year,
            poster: poster || parent.poster,
            description: description || '',
            duration: duration || '',
            videoUrl: videoUrl || '',
            views: 0, likes: 0,
            createdAt: new Date().toISOString(), updatedAt: new Date().toISOString()
        };
        
        if (!db.parts) db.parts = [];
        db.parts.push(newPart);
        fs.writeFileSync('data/db.json', JSON.stringify(db, null, 2));
        res.json({ success: true, message: 'تم الإضافة', part: newPart });
    } catch (error) {
        res.status(500).json({ error: 'خطأ' });
    }
});

