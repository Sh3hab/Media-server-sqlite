app.post('/api/seasons', authenticateAdmin, (req, res) => {
    try {
        const db = JSON.parse(fs.readFileSync('data/db.json', 'utf8'));
        const { seriesId, seasonNumber, title, poster, description, year } = req.body;
        
        const series = db.series.find(s => s.id === seriesId);
