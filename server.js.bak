app.put('/api/genres/:id', authenticateAdmin, (req, res) => {
    try {
        const db = JSON.parse(fs.readFileSync('data/db.json', 'utf8'));
        const index = db.genres.findIndex(g => g.id === req.params.id);
        if (index === -1) return res.status(404).json({ error: 'غير موجود' });
        
        const oldName = db.genres[index].name;
        db.genres[index] = { ...db.genres[index], ...req.body, updatedAt: new Date().toISOString() };
        
        // تحديث الاسم في المحتويات
        if (req.body.name && req.body.name !== oldName) {
            db.series.forEach(content => {
                if (content.genres && content.genres.includes(oldName)) {
                    content.genres[content.genres.indexOf(oldName)] = req.body.name;
                }
            });
        }
        
        fs.writeFileSync('data/db.json', JSON.stringify(db, null, 2));
        res.json({ success: true, message: 'تم التحديث', genre: db.genres[index] });
    } catch (error) {
        res.status(500).json({ error: 'خطأ' });
    }
});

