    }
});


// ==================== 10. إدارة الملفات (Files Management) ====================


// دالة مساعدة لحساب حجم المجلد
function getFolderSize(folderPath) {
    let totalSize = 0;
    if (!fs.existsSync(folderPath)) return totalSize;
    
    const files = fs.readdirSync(folderPath);
    files.forEach(file => {
        const filePath = path.join(folderPath, file);
        const stat = fs.statSync(filePath);
        if (stat.isFile()) {
            totalSize += stat.size;
        }
    });
    return totalSize;
}

// دالة مساعدة لفحص ارتباط الملف
function checkFileLinks(db, fileName, filePath) {
    const linkedTo = [];
    const fullUrl = `/uploads/${filePath.replace(/\\/g, '/')}`;
    const fileNameOnly = path.basename(fileName);
    
    // البحث في المسلسلات والأفلام
    db.series.forEach(content => {
        let linked = false;
        const fields = [];
        
        if (content.poster && (content.poster.includes(fileNameOnly) || content.poster === fullUrl)) {
            fields.push('poster');
            linked = true;
        }
        if (content.videoUrl && (content.videoUrl.includes(fileNameOnly) || content.videoUrl === fullUrl)) {
            fields.push('videoUrl');
            linked = true;
        }
        if (content.subtitleUrl && (content.subtitleUrl.includes(fileNameOnly) || content.subtitleUrl === fullUrl)) {
            fields.push('subtitleUrl');
            linked = true;
        }
        
        if (linked) {
            linkedTo.push({
                id: content.id,
                title: content.title,
                type: content.isMovie ? 'فيلم' : 'مسلسل',
                fields: fields
            });
        }
    });
    
    // البحث في الممثلين
    db.actors?.forEach(actor => {
        if (actor.image && (actor.image.includes(fileNameOnly) || actor.image === fullUrl)) {
            linkedTo.push({
                id: actor.id,
                title: actor.name,
                type: 'ممثل',
                fields: ['image']
            });
        }
    });
    
    // البحث في المواسم
    db.seasons?.forEach(season => {
        if (season.poster && (season.poster.includes(fileNameOnly) || season.poster === fullUrl)) {
            linkedTo.push({
                id: season.id,
                title: season.title,
                type: 'موسم',
                fields: ['poster']
            });
        }
    });
    
    // البحث في الأجزاء
    db.parts?.forEach(part => {
        if (part.poster && (part.poster.includes(fileNameOnly) || part.poster === fullUrl)) {
            linkedTo.push({
                id: part.id,
                title: part.title,
                type: 'جزء',
                fields: ['poster']
            });
        }
        if (part.videoUrl && (part.videoUrl.includes(fileNameOnly) || part.videoUrl === fullUrl)) {
            linkedTo.push({
                id: part.id,
                title: part.title,
                type: 'جزء',
                fields: ['videoUrl']
            });
        }
    });
    
    // البحث في الدول
    db.countries?.forEach(country => {
        if (country.flag && (country.flag.includes(fileNameOnly) || country.flag === fullUrl)) {
            linkedTo.push({
                id: country.id,
                title: country.name,
                type: 'دولة',
                fields: ['flag']
            });
        }
    });
    
    return linkedTo;
}

// دالة مساعدة لفحص نوع الملف
function getFileCategory(filename, mimetype) {
    const ext = path.extname(filename).toLowerCase();
    const imageExts = ['.jpg', '.jpeg', '.png', '.gif', '.bmp', '.webp', '.svg'];
    const videoExts = ['.mp4', '.mkv', '.avi', '.mov', '.wmv', '.flv', '.webm'];
    const subtitleExts = ['.vtt', '.srt', '.ass', '.ssa'];
    
    if (imageExts.includes(ext) || mimetype?.startsWith('image/')) return 'image';
    if (videoExts.includes(ext) || mimetype?.startsWith('video/')) return 'video';
    if (subtitleExts.includes(ext)) return 'subtitle';
    return 'other';
}




// دالة مساعدة لتنسيق حجم الملف
function formatBytes(bytes, decimals = 2) {
    if (bytes === 0) return '0 Bytes';
    const k = 1024;
    const dm = decimals < 0 ? 0 : decimals;
    const sizes = ['Bytes', 'KB', 'MB', 'GB', 'TB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return parseFloat((bytes / Math.pow(k, i)).toFixed(dm)) + ' ' + sizes[i];
}

// ربط ملف بمحتوى
app.post('/api/files/link', authenticateAdmin, (req, res) => {
    try {
        const { filePath, contentType, contentId, field } = req.body;
        const db = JSON.parse(fs.readFileSync('data/db.json', 'utf8'));
        const fileUrl = `/uploads/${filePath}`;
        
        let updated = false;
        let contentTitle = '';
        
        // البحث عن المحتوى وتحديثه
        if (contentType === 'series' || contentType === 'movie') {
            const item = db.series.find(s => s.id === contentId);
            if (item) {
                if (field === 'poster') item.poster = fileUrl;
                else if (field === 'videoUrl') item.videoUrl = fileUrl;
                else if (field === 'subtitleUrl') item.subtitleUrl = fileUrl;
                else item[field] = fileUrl;
                contentTitle = item.title;
                updated = true;
            }
        } else if (contentType === 'actor') {
            const item = db.actors?.find(a => a.id === contentId);
            if (item) {
                item.image = fileUrl;
                contentTitle = item.name;
                updated = true;
            }
        } else if (contentType === 'season') {
            const item = db.seasons?.find(s => s.id === contentId);
            if (item) {
                item.poster = fileUrl;
                contentTitle = item.title;
                updated = true;
            }
        } else if (contentType === 'episode') {
            const item = db.episodes?.find(e => e.id === contentId);
            if (item) {
                if (field === 'videoUrl') item.videoUrl = fileUrl;
                else if (field === 'thumbnail') item.thumbnail = fileUrl;
                contentTitle = item.title;
                updated = true;
            }
        } else if (contentType === 'part') {
            const item = db.parts?.find(p => p.id === contentId);
            if (item) {
                if (field === 'poster') item.poster = fileUrl;
                else if (field === 'videoUrl') item.videoUrl = fileUrl;
                contentTitle = item.title;
                updated = true;
            }
        } else if (contentType === 'country') {
            const item = db.countries?.find(c => c.id === contentId);
            if (item) {
                item.flag = fileUrl;
                contentTitle = item.name;
                updated = true;
            }
        }
        
        if (updated) {
            fs.writeFileSync('data/db.json', JSON.stringify(db, null, 2));
            
            // تسجيل العملية
            const logs = JSON.parse(fs.readFileSync('data/logs.json', 'utf8'));
            logs.logs.unshift({
                endpoint: '/api/files/link',
                method: 'POST',
                ip: req.ip,
                timestamp: new Date().toISOString(),
                admin: req.headers['x-admin-user'] || 'admin',
                details: { filePath, contentType, contentTitle, field }
            });
            fs.writeFileSync('data/logs.json', JSON.stringify(logs, null, 2));
            
            res.json({ success: true, message: 'تم ربط الملف بنجاح' });
        } else {
            res.json({ success: false, error: 'لم يتم العثور على المحتوى' });
        }
    } catch (error) {
        console.error('Error linking file:', error);
        res.status(500).json({ success: false, error: error.message });
    }
});

// جلب قائمة الملفات (نسخة مصححة 100%)

// حذف ملف
app.post('/api/files/delete', authenticateAdmin, (req, res) => {
    try {
        const { filePath } = req.body;
        const fullPath = path.join(__dirname, 'uploads', filePath);
        
        if (!fs.existsSync(fullPath)) {
            return res.json({ success: false, error: 'الملف غير موجود' });
        }
        
        // التحقق من عدم استخدام الملف قبل حذفه
        const db = JSON.parse(fs.readFileSync('data/db.json', 'utf8'));
        const fileUrl = `/uploads/${filePath}`;
        const fileName = path.basename(filePath);
        
        let inUse = false;
        let usedBy = [];
        
        // فحص المسلسلات والأفلام
        db.series.forEach(content => {
            if (content.poster === fileUrl || content.poster?.includes(fileName) ||
                content.videoUrl === fileUrl || content.videoUrl?.includes(fileName) ||
                content.subtitleUrl === fileUrl || content.subtitleUrl?.includes(fileName)) {
                inUse = true;
                usedBy.push({ type: content.isMovie ? 'فيلم' : 'مسلسل', title: content.title });
            }
        });
        
        // فحص الممثلين
        db.actors?.forEach(actor => {
            if (actor.image === fileUrl || actor.image?.includes(fileName)) {
                inUse = true;
                usedBy.push({ type: 'ممثل', title: actor.name });
            }
        });
        
        if (inUse) {
            const usedByText = usedBy.map(u => `${u.title} (${u.type})`).join('، ');
            return res.json({ 
                success: false, 
                error: `لا يمكن حذف الملف لأنه مستخدم في: ${usedByText}` 
            });
        }
        
        // حذف الملف
        fs.unlinkSync(fullPath);
        
        // حذف المجلد إذا كان فارغاً
        const parentDir = path.dirname(fullPath);
        if (fs.existsSync(parentDir) && fs.readdirSync(parentDir).length === 0) {
            fs.rmdirSync(parentDir);
        }
        
        // تسجيل العملية
        const logs = JSON.parse(fs.readFileSync('data/logs.json', 'utf8'));
        logs.logs.unshift({
            endpoint: '/api/files/delete',
            method: 'POST',
            ip: req.ip,
            timestamp: new Date().toISOString(),
            admin: req.headers['x-admin-user'] || 'admin',
            details: { filePath, fileSize: fs.statSync(fullPath).size }
        });
        fs.writeFileSync('data/logs.json', JSON.stringify(logs, null, 2));
        
        res.json({ success: true, message: 'تم حذف الملف بنجاح' });
    } catch (error) {
        console.error('Error deleting file:', error);
        res.status(500).json({ success: false, error: error.message });
    }
});

// جلب إحصائيات الملفات فقط
app.get('/api/files/stats', authenticateAdmin, (req, res) => {
    try {
        const uploadDir = path.join(__dirname, 'uploads');
        const stats = {
            totalFiles: 0,
            totalSize: 0,
            byFolder: {},
            byType: {
                images: { count: 0, size: 0, formats: {} },
                videos: { count: 0, size: 0, formats: {} },
                subtitles: { count: 0, size: 0, formats: {} },
                others: { count: 0, size: 0, formats: {} }
            }
        };
        
        function scanDir(dir, folder = '') {
            if (!fs.existsSync(dir)) return;
            
            const items = fs.readdirSync(dir);
            
            items.forEach(item => {
                const itemPath = path.join(dir, item);
                const stat = fs.statSync(itemPath);
                
                if (stat.isDirectory()) {
                    scanDir(itemPath, path.join(folder, item));
                } else {
                    const ext = path.extname(item).toLowerCase();
                    const size = stat.size;
                    const category = getFileCategory(item, '');
                    
                    stats.totalFiles++;
                    stats.totalSize += size;
                    
                    // إحصائيات حسب المجلد
                    const folderName = folder || 'root';
                    if (!stats.byFolder[folderName]) {
                        stats.byFolder[folderName] = { count: 0, size: 0 };
                    }
                    stats.byFolder[folderName].count++;
                    stats.byFolder[folderName].size += size;
                    
                    // إحصائيات حسب النوع
                    if (category === 'image') {
                        stats.byType.images.count++;
                        stats.byType.images.size += size;
                        stats.byType.images.formats[ext] = (stats.byType.images.formats[ext] || 0) + 1;
                    } else if (category === 'video') {
                        stats.byType.videos.count++;
                        stats.byType.videos.size += size;
                        stats.byType.videos.formats[ext] = (stats.byType.videos.formats[ext] || 0) + 1;
                    } else if (category === 'subtitle') {
                        stats.byType.subtitles.count++;
                        stats.byType.subtitles.size += size;
                        stats.byType.subtitles.formats[ext] = (stats.byType.subtitles.formats[ext] || 0) + 1;
                    } else {
                        stats.byType.others.count++;
                        stats.byType.others.size += size;
                        stats.byType.others.formats[ext] = (stats.byType.others.formats[ext] || 0) + 1;
                    }
                }
            });
        }
        
        scanDir(uploadDir);
        
        res.json({
            success: true,
            stats: {
                ...stats,
                totalSizeFormatted: formatBytes(stats.totalSize),
                byFolder: Object.entries(stats.byFolder).map(([name, data]) => ({
                    name,
                    count: data.count,
                    size: data.size,
                    sizeFormatted: formatBytes(data.size)
                }))
            }
        });
    } catch (error) {
        console.error('Error getting file stats:', error);
        res.status(500).json({ success: false, error: error.message });
    }
});

// تنظيف الملفات غير المستخدمة
app.post('/api/files/cleanup', authenticateAdmin, (req, res) => {
    try {
        const uploadDir = path.join(__dirname, 'uploads');
        const db = JSON.parse(fs.readFileSync('data/db.json', 'utf8'));
        const usedFiles = new Set();
        const deletedFiles = [];
        const totalSize = { before: 0, after: 0 };
        
        // جمع جميع الملفات المستخدمة
        function collectUsedFiles() {
            // المسلسلات والأفلام
            db.series.forEach(content => {
                if (content.poster) usedFiles.add(path.basename(content.poster));
                if (content.videoUrl) usedFiles.add(path.basename(content.videoUrl));
                if (content.subtitleUrl) usedFiles.add(path.basename(content.subtitleUrl));
            });
            
            // الممثلين
            db.actors?.forEach(actor => {
                if (actor.image) usedFiles.add(path.basename(actor.image));
            });
            
            // المواسم
            db.seasons?.forEach(season => {
                if (season.poster) usedFiles.add(path.basename(season.poster));
            });
            
            // الأجزاء
            db.parts?.forEach(part => {
                if (part.poster) usedFiles.add(path.basename(part.poster));
                if (part.videoUrl) usedFiles.add(path.basename(part.videoUrl));
            });
            
            // الدول
            db.countries?.forEach(country => {
                if (country.flag) usedFiles.add(path.basename(country.flag));
            });
        }
        
        collectUsedFiles();
        
        // فحص وحذف الملفات غير المستخدمة
        function scanAndClean(dir) {
            if (!fs.existsSync(dir)) return;
            
            const items = fs.readdirSync(dir);
            
            items.forEach(item => {
                const itemPath = path.join(dir, item);
                const stat = fs.statSync(itemPath);
                
                if (stat.isDirectory()) {
                    scanAndClean(itemPath);
                    
                    // حذف المجلد إذا كان فارغاً بعد التنظيف
                    if (fs.readdirSync(itemPath).length === 0) {
                        fs.rmdirSync(itemPath);
                    }
                } else {
                    totalSize.before += stat.size;
                    
                    if (!usedFiles.has(item) && !item.startsWith('default')) {
                        // الملف غير مستخدم، احذفه
                        fs.unlinkSync(itemPath);
                        deletedFiles.push({
                            name: item,
                            path: path.relative(uploadDir, itemPath),
                            size: stat.size
                        });
                    } else {
                        totalSize.after += stat.size;
                    }
                }
            });
        }
        
        scanAndClean(uploadDir);
        
        // تسجيل العملية
        const logs = JSON.parse(fs.readFileSync('data/logs.json', 'utf8'));
        logs.logs.unshift({
            endpoint: '/api/files/cleanup',
            method: 'POST',
            ip: req.ip,
            timestamp: new Date().toISOString(),
            admin: req.headers['x-admin-user'] || 'admin',
            details: { 
                deletedCount: deletedFiles.length,
                freedSpace: formatBytes(totalSize.before - totalSize.after),
                deletedFiles: deletedFiles.map(f => f.name)
            }
        });
        fs.writeFileSync('data/logs.json', JSON.stringify(logs, null, 2));
        
        res.json({
            success: true,
            message: `تم حذف ${deletedFiles.length} ملف غير مستخدم`,
            deleted: deletedFiles,
            freedSpace: formatBytes(totalSize.before - totalSize.after),
            totalBefore: formatBytes(totalSize.before),
            totalAfter: formatBytes(totalSize.after)
        });
    } catch (error) {
        console.error('Error cleaning files:', error);
        res.status(500).json({ success: false, error: error.message });
    }
});

// البحث في الملفات
app.get('/api/files/search', authenticateAdmin, (req, res) => {
    try {
        const query = req.query.q?.toLowerCase() || '';
        const category = req.query.category || 'all';
        const uploadDir = path.join(__dirname, 'uploads');
        const db = JSON.parse(fs.readFileSync('data/db.json', 'utf8'));
        const results = [];
        
        function searchDir(dir, relativePath = '') {
            if (!fs.existsSync(dir)) return;
            
            const items = fs.readdirSync(dir);
            
            items.forEach(item => {
                const itemPath = path.join(dir, item);
                const stat = fs.statSync(itemPath);
                const relative = path.join(relativePath, item).replace(/\\/g, '/');
                
                if (stat.isDirectory()) {
                    searchDir(itemPath, relative);
                } else {
                    const itemCategory = getFileCategory(item, '');
                    
                    if (category !== 'all' && itemCategory !== category) return;
                    
                    if (query === '' || item.toLowerCase().includes(query)) {
                        const linkedTo = checkFileLinks(db, item, relative);
                        
                        results.push({
                            name: item,
                            path: relative,
                            url: `/uploads/${relative}`,
                            size: stat.size,
                            sizeFormatted: formatBytes(stat.size),
                            category: itemCategory,
                            modified: stat.mtime,
                            created: stat.birthtime,
                            linkedTo: linkedTo,
                            isLinked: linkedTo.length > 0
                        });
                    }
                }
            });
        }
        
        searchDir(uploadDir);
        
        res.json({ success: true, results: results });
    } catch (error) {
        console.error('Error searching files:', error);
        res.status(500).json({ success: false, error: error.message });
    }
});


// 404 & Error Handlers
app.use((req, res) => {
    res.status(404).sendFile(path.join(__dirname, '404.html'));
});

app.use((err, req, res, next) => {
    console.error(err.stack);
    res.status(500).json({ error: 'حدث خطأ في الخادم', message: err.message });
});

