});

app.post('/api/watch/:id', (req, res) => {
    try {
        const db = JSON.parse(fs.readFileSync('data/db.json', 'utf8'));
        const { type = 'episode' } = req.body;
        
        if (type === 'episode') {
            const index = db.episodes.findIndex(ep => ep.id === req.params.id);
            if (index !== -1) {
                db.episodes[index].views = (db.episodes[index].views || 0) + 1;
                const sIndex = db.series.findIndex(s => s.id === db.episodes[index].seriesId);
                if (sIndex !== -1) db.series[sIndex].views = (db.series[sIndex].views || 0) + 1;
            }
        } else {
            const index = db.series.findIndex(s => s.id === req.params.id);
            if (index !== -1) db.series[index].views = (db.series[index].views || 0) + 1;
        }
        
        fs.writeFileSync('data/db.json', JSON.stringify(db, null, 2));
        res.json({ success: true });
    } catch (error) {
        res.status(500).json({ error: 'خطأ' });
    }
});

