            latestSeries: db.series.filter(s => !s.isMovie).sort((a, b) => new Date(b.createdAt) - new Date(a.createdAt)).slice(0, 10),
            latestMovies: db.series.filter(s => s.isMovie).sort((a, b) => new Date(b.createdAt) - new Date(a.createdAt)).slice(0, 10),
