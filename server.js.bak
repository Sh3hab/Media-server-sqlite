const express = require('express');
const multer = require('multer');
const path = require('path');
const fs = require('fs');
const cors = require('cors');

const app = express();
const PORT = 3000;


app.use(cors());
app.use(express.json());
app.use(express.urlencoded({ extended: true }));
app.use('/uploads', express.static(path.join(__dirname, 'uploads')));
app.use(express.static(__dirname)); 


const folders = [
    'data',
    'uploads/posters',
    'uploads/actors',
    'uploads/episodes',
    'uploads/movies',
    'uploads/flags',
    'uploads/others'
];

folders.forEach(folder => {
    if (!fs.existsSync(folder)) {
        fs.mkdirSync(folder, { recursive: true });
    }
});


const initFiles = [
    { 
        path: 'data/db.json', 
        default: { 
            series: [], 
            movies: [], 
            actors: [], 
            genres: [], 
            countries: [], 
            tags: [], 
            parts: [],
            promotions: [],
            seasons: [],
            episodes: [],
            users: []
        } 
    },
    { 
        path: 'data/admins.json', 
        default: { 
            admins: [
                {
                    id: "1",
                    username: "admin",
                    password: "admin123",
                    name: "Shihab ban",
                    role: "superadmin",
                    createdAt: new Date().toISOString()
                }
            ] 
        } 
    },
    { 
        path: 'data/logs.json', 
        default: { 
            logs: [] 
        } 
    }
];

initFiles.forEach(file => {
    if (!fs.existsSync(file.path)) {
        fs.writeFileSync(file.path, JSON.stringify(file.default, null, 2));
    }
});


const ADMIN_TOKEN = 'shihab-admin-token-2025';


const authenticateAdmin = (req, res, next) => {
    const token = req.headers['x-admin-token'];
    
    if (token === ADMIN_TOKEN) {
        next();
    } else {
        res.status(401).json({ error: 'الوصول مرفوض. يلزم تسجيل الدخول.' });
    }
};


const logRequest = (req, res, next) => {
    try {
        const logsPath = 'data/logs.json';
        if (fs.existsSync(logsPath)) {
            const logs = JSON.parse(fs.readFileSync(logsPath, 'utf8'));
            logs.logs.unshift({
                endpoint: req.originalUrl,
                method: req.method,
                ip: req.ip,
                timestamp: new Date().toISOString(),
                admin: req.headers['x-admin-user'] || 'unknown'
            });
            
            if (logs.logs.length > 1000) logs.logs = logs.logs.slice(0, 1000);
            fs.writeFileSync(logsPath, JSON.stringify(logs, null, 2));
        }
    } catch (err) {
        console.error("Error writing logs:", err);
    }
    next();
};

app.use(logRequest);


const storage = multer.diskStorage({
    destination: (req, file, cb) => {
        const type = req.query.type || req.body.type || 'other';
        let folder = 'uploads/';
        
        switch(type) {
            case 'poster': folder += 'posters/'; break;
            case 'actor': folder += 'actors/'; break;
            case 'episode': folder += 'episodes/'; break;
            case 'movie': folder += 'movies/'; break;
            case 'flag': folder += 'flags/'; break;
            default: folder += 'others/';
        }
        
        if (!fs.existsSync(folder)) {
            fs.mkdirSync(folder, { recursive: true });
        }
        
        cb(null, folder);
    },
    filename: (req, file, cb) => {
        const uniqueName = Date.now() + '-' + Math.round(Math.random() * 1E9) + path.extname(file.originalname);
        cb(null, uniqueName);
    }
});

const upload = multer({ 
    storage,
    limits: { fileSize: 3.5 * 1024 * 1024 * 1024 }, 
    fileFilter: (req, file, cb) => {

        cb(null, true); 
    }
});


app.get('/', (req, res) => {
    res.sendFile(path.join(__dirname, 'index.html'));
});

app.get('/admin', (req, res) => {
    res.sendFile(path.join(__dirname, 'admin.html'));
});

app.get('/srt', (req, res) => {
    res.sendFile(path.join(__dirname, 'conv.html'));
});

app.get('/404', (req, res) => {
    res.sendFile(path.join(__dirname, '404.html'));
});

app.post('/api/admin/login', (req, res) => {
    const { username, password } = req.body;
    const adminsData = JSON.parse(fs.readFileSync('data/admins.json', 'utf8'));
    const admin = adminsData.admins.find(a => a.username === username && a.password === password);
    
    if (admin) {
        res.json({ 
            success: true, 
            token: ADMIN_TOKEN,
            admin: {
                id: admin.id,
                username: admin.username,
                name: admin.name,
                role: admin.role
            }
        });
    } else {
        res.status(401).json({ success: false, error: 'اسم المستخدم أو كلمة المرور غير صحيحة' });
    }
});


app.post('/api/upload', authenticateAdmin, upload.single('file'), (req, res) => {
    try {
        if (!req.file) return res.status(400).json({ error: 'لم يتم رفع أي ملف' });
        
        const type = req.query.type || req.body.type || 'other';
        const folderName = type === 'poster' ? 'posters' : (['actor', 'episode', 'movie', 'flag'].includes(type) ? type + 's' : 'others');
        const fileUrl = `/uploads/${folderName}/${req.file.filename}`;
        
        res.json({ 
            success: true, 
            filename: req.file.filename,
            originalname: req.file.originalname,
            url: fileUrl,
            size: req.file.size,
            mimetype: req.file.mimetype,
            type: type
        });
    } catch (error) {
        res.status(500).json({ error: error.message });
    }
});


app.get('/api/series', (req, res) => {
    try {
        const db = JSON.parse(fs.readFileSync('data/db.json', 'utf8'));
        const series = db.series.map(s => ({
            ...s,
            seasons: db.seasons.filter(season => season.seriesId === s.id),
            totalEpisodes: db.episodes.filter(ep => ep.seriesId === s.id).length
        }));
        series.sort((a, b) => a.order - b.order);
        res.json(series);
    } catch (error) {
        res.status(500).json({ error: 'خطأ في قراءة البيانات' });
    }
});

app.get('/api/movies', (req, res) => {
    try {
        const db = JSON.parse(fs.readFileSync('data/db.json', 'utf8'));
        const movies = db.series.filter(s => s.isMovie === true);
        movies.sort((a, b) => a.order - b.order);
        res.json(movies);
    } catch (error) {
        res.status(500).json({ error: 'خطأ في قراءة الأفلام' });
    }
});


app.post('/api/movies', (req, res) => {
    const db = JSON.parse(fs.readFileSync('data/db.json'));
    const newMovie = {
        id: Date.now().toString(),
        title: req.body.title,

        videoUrl: req.body.videoUrl || '', 
        subtitleUrl: req.body.subtitleUrl || ''
    };
    db.movies.push(newMovie);
    fs.writeFileSync('data/db.json', JSON.stringify(db, null, 2));
    res.json(newMovie);
});



app.get('/api/series/:id', (req, res) => {
    try {
        const db = JSON.parse(fs.readFileSync('data/db.json', 'utf8'));
        const series = db.series.find(s => s.id === req.params.id);
        
        if (!series) return res.status(404).json({ error: 'المحتوى غير موجود' });
        
        const seasons = db.seasons.filter(season => season.seriesId === series.id);
        const episodes = db.episodes.filter(ep => ep.seriesId === series.id);
        

        const actors = (series.actors || []).map(actorId => db.actors.find(a => a.id === actorId)).filter(Boolean);
        

        const actorRoles = series.actorRoles || [];

        res.json({
            ...series,
            seasons,
            episodes,
            actors,
            actorRoles, 
            totalEpisodes: episodes.length,
            totalSeasons: seasons.length
        });
    } catch (error) {
        res.status(500).json({ error: 'خطأ في قراءة البيانات' });
    }
});

app.post('/api/series', authenticateAdmin, (req, res) => {
    try {
        const db = JSON.parse(fs.readFileSync('data/db.json', 'utf8'));
        const { 
                title, year, poster, rating, order, promoted, description, 
                tags, genres, countries, actors, isMovie, duration, director, language,
                videoUrl, subtitleUrl 
            } = req.body;

        
        const id = 'series_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9);
        
        const newSeries = {
            id: id,
            title: title.trim(),
            year: parseInt(year) || new Date().getFullYear(),
            poster: poster || '/uploads/posters/default.png',
            rating: parseFloat(rating) || 0.0,
            order: parseInt(order) || 0,
            promoted: promoted === true || promoted === 'true',
            description: description || '',
            videoUrl: videoUrl || '',
            subtitleUrl: subtitleUrl || '', 
            tags: Array.isArray(tags) ? tags : (tags ? tags.split(',').map(t => t.trim()) : []),
            genres: Array.isArray(genres) ? genres : (genres ? genres.split(',').map(g => g.trim()) : []),
            countries: Array.isArray(countries) ? countries : (countries ? countries.split(',').map(c => c.trim()) : []),
            actors: Array.isArray(actors) ? actors : (actors ? actors.split(',').map(a => a.trim()) : []),
            isMovie: isMovie === true || isMovie === 'true',
            duration: duration || '',
            director: director || '',
            language: language || 'ar',
            createdAt: new Date().toISOString(),
            updatedAt: new Date().toISOString(),
            views: 0,
            likes: 0,
            type: (isMovie === true || isMovie === 'true') ? 'movie' : 'series'
        };
        
        db.series.push(newSeries);
        fs.writeFileSync('data/db.json', JSON.stringify(db, null, 2));
        
        res.json({ success: true, message: 'تم الإضافة بنجاح', series: newSeries });
    } catch (error) {
        res.status(500).json({ error: 'خطأ في الحفظ: ' + error.message });
    }
});

app.put('/api/series/:id', authenticateAdmin, (req, res) => {
    try {
        const db = JSON.parse(fs.readFileSync('data/db.json', 'utf8'));
        const index = db.series.findIndex(s => s.id === req.params.id);
        
        if (index === -1) return res.status(404).json({ error: 'غير موجود' });
        
        const updatedSeries = {
            ...db.series[index],
            ...req.body,
            updatedAt: new Date().toISOString()
        };

        if (req.body.year) updatedSeries.year = parseInt(req.body.year);
        if (req.body.rating) updatedSeries.rating = parseFloat(req.body.rating);
        if (req.body.order) updatedSeries.order = parseInt(req.body.order);
        
        db.series[index] = updatedSeries;
        fs.writeFileSync('data/db.json', JSON.stringify(db, null, 2));
        
        res.json({ success: true, message: 'تم التحديث بنجاح', series: updatedSeries });
    } catch (error) {
        res.status(500).json({ error: 'خطأ في التحديث' });
    }
});

app.delete('/api/series/:id', authenticateAdmin, (req, res) => {
    try {
        const db = JSON.parse(fs.readFileSync('data/db.json', 'utf8'));
        const index = db.series.findIndex(s => s.id === req.params.id);
        
        if (index === -1) return res.status(404).json({ error: 'غير موجود' });

        db.seasons = db.seasons.filter(s => s.seriesId !== req.params.id);
        db.episodes = db.episodes.filter(e => e.seriesId !== req.params.id);

        
        const deleted = db.series.splice(index, 1)[0];
        fs.writeFileSync('data/db.json', JSON.stringify(db, null, 2));
        
        res.json({ success: true, message: 'تم الحذف بنجاح', series: deleted });
    } catch (error) {
        res.status(500).json({ error: 'خطأ في الحذف' });
    }
});


